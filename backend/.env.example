PORT=4000

# Supabase PostgreSQL Connection
# Go to: supabase.com -> Your Project -> Settings -> Database -> Connection String -> URI
DATABASE_URL="postgresql://postgres:[TU_PASSWORD_SUPABASE]@db.[TU_PROJECT_ID].supabase.co:5432/postgres"

# For Prisma Migrations (use direct connection, not pooler)
DIRECT_URL="postgresql://postgres:[TU_PASSWORD_SUPABASE]@db.[TU_PROJECT_ID].supabase.co:5432/postgres"

JWT_SECRET="[GENERA_UN_SECRET_DE_64_CARACTERES_ALEATORIOS]"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# AI Assistant (OpenAI)
OPENAI_API_KEY="sk-[TU_API_KEY_DE_OPENAI]"
